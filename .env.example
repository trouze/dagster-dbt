# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
# Load with: source .env

# ── dbt platform ──────────────────────────────────────────────────────────────
# Find these in your dbt platform account settings.
export DBT_CLOUD_ACCOUNT_ID=
export DBT_CLOUD_PROJECT_ID=
export DBT_CLOUD_ENVIRONMENT_ID=
export DBT_API_KEY=
# Base URL for your dbt platform instance (no trailing slash).
# Multi-tenant: https://cloud.getdbt.com
# Single-tenant: https://<your-tenant>.getdbt.com
export DBT_BASE_URL=https://cloud.getdbt.com
# The branch the git-watch sensor polls for manifest refreshes.
export DBT_CLOUD_GIT_BRANCH=main

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal access token (or fine-grained token) with repo read access.
# Required by the git-watch sensor to detect new commits.
export GITHUB_TOKEN=

# ── Snowflake ─────────────────────────────────────────────────────────────────
# Shared by the Dagster Snowflake resource and dbt profiles.yml.
export SNOWFLAKE_ACCOUNT=        # e.g. xy12345.us-east-1
export SNOWFLAKE_USER=
export SNOWFLAKE_DATABASE=
export SNOWFLAKE_WAREHOUSE=
export SNOWFLAKE_SCHEMA=dev
export SNOWFLAKE_ROLE=
# Key-pair auth (recommended). Set KEY_PATH or PASSWORD, not both.
export SNOWFLAKE_KEY_PATH=       # absolute path to your private key file
export SNOWFLAKE_PASSPHRASE=     # leave blank if the key is unencrypted
export SNOWFLAKE_PASSWORD=       # alternative: password auth instead of key-pair
