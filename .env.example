# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── dbt platform ──────────────────────────────────────────────────────────────
# Find these in your dbt platform account settings.
DBT_CLOUD_ACCOUNT_ID=
DBT_CLOUD_PROJECT_ID=
DBT_CLOUD_ENVIRONMENT_ID=
DBT_API_KEY=
# Base URL for your dbt platform instance (no trailing slash).
# Multi-tenant: https://cloud.getdbt.com
# Single-tenant: https://<your-tenant>.getdbt.com
DBT_BASE_URL=https://cloud.getdbt.com
# The branch the git-watch sensor polls for manifest refreshes.
DBT_CLOUD_GIT_BRANCH=main

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal access token (or fine-grained token) with repo read access.
# Required by the git-watch sensor to detect new commits.
GITHUB_TOKEN=

# ── Snowflake ─────────────────────────────────────────────────────────────────
# Shared by the Dagster Snowflake resource and dbt profiles.yml.
SNOWFLAKE_ACCOUNT=        # e.g. xy12345.us-east-1
SNOWFLAKE_USER=
SNOWFLAKE_DATABASE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_SCHEMA=dev
SNOWFLAKE_ROLE=
# Key-pair auth (recommended). Set KEY_PATH or PASSWORD, not both.
SNOWFLAKE_KEY_PATH=       # absolute path to your private key file
SNOWFLAKE_PASSPHRASE=     # leave blank if the key is unencrypted
SNOWFLAKE_PASSWORD=       # alternative: password auth instead of key-pair
